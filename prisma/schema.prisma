// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hero {
  id          String   @id @default(cuid())
  title_en    String
  title_id    String
  subtitle_en String
  subtitle_id String
  cta_en      String   @default("View My Work")
  cta_id      String   @default("Lihat Karya Saya")
  badge_en    String   @default("Available for Freelance")
  badge_id    String   @default("Tersedia untuk Freelance")
  image       String?
  cv_url      String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id             String   @id @default(cuid())
  description_en String   @db.Text
  description_id String   @db.Text
  image          String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id        String      @id @default(cuid())
  name      String
  level     Int         @default(80)
  category  String      @default("Technical")
  icon      String?
  published Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  title_en       String
  title_id       String
  description_en String   @db.Text
  description_id String   @db.Text
  image          String?
  tech_stack     String[]
  link           String?
  github         String?
  category       String   @default("Web")
  featured       Boolean  @default(false)
  published      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Experience {
  id             String    @id @default(cuid())
  title_en       String
  title_id       String
  company        String
  location       String?
  start_date     DateTime
  end_date       DateTime?
  description_en String    @db.Text
  description_id String    @db.Text
  published      Boolean   @default(true)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  name      String
  link      String
  icon      String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  email     String
  phone     String?
  location  String?
  title_en  String?  @default("Let's Talk")
  title_id  String?  @default("Mari Bicara")
  desc_en   String?  @default("I'm always open to new opportunities and collaborations. Whether you have a project, a question, or just want to say hi — my inbox is always open.")
  desc_id   String?  @default("Saya selalu terbuka untuk peluang dan kolaborasi baru. Apapun yang ingin Anda diskusikan, jangan ragu untuk menghubungi saya.")
  footer_copy String? @default("© 2026 Helmi. Hak cipta dilindungi.")
  footer_made String? @default("© 2026 Helmi. All rights reserved.")
  portfolio_extra_en String? @default("Languages: Indonesian (Native), English (Professional)")
  portfolio_extra_id String? @default("Bahasa: Indonesia (Native), Inggris (Profesional)")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Certificate {
  id            String   @id @default(cuid())
  name          String
  issuer        String
  issue_date    DateTime
  credential_id String?
  link          String?
  file_url      String?
  published     Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([path])
}

enum Role {
  ADMIN
  SUPER_ADMIN
}
